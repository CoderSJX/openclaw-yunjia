{
  "name": "openclaw-yunjia",
  "version": "1.0.2",
  "description": "Yunjia Chat channel plugin for OpenClaw",
  "keywords": [
    "channel",
    "chat",
    "openclaw",
    "plugin",
    "yunjia"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yunjia-chat-sdk": "^1.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "openclaw": "^2026.2.27",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "yunjia",
      "label": "Yunjia Chat",
      "selectionLabel": "Yunjia Chat (Socket)",
      "docsPath": "/channels/yunjia",
      "docsLabel": "yunjia",
      "blurb": "Connect Yunjia chat service to OpenClaw through the official SDK.",
      "order": 92
    },
    "install": {
      "npmSpec": "openclaw-yunjia",
      "defaultChoice": "npm"
    }
  }
}
